# PostgreSQL
POSTGRES_DB=datahub
POSTGRES_USER=datahub_user
POSTGRES_PASSWORD=change_me_postgres

# PgBouncer — Connection Pooling vor PostgreSQL
# PGBOUNCER_POOL_MODE: transaction (empfohlen), session oder statement
# PGBOUNCER_MAX_CLIENT_CONN: max. gleichzeitige Client-Verbindungen
# PGBOUNCER_DEFAULT_POOL_SIZE: max. PostgreSQL-Verbindungen pro Pool
PGBOUNCER_DATABASE=datahub
PGBOUNCER_AUTH_USER=datahub_user
PGBOUNCER_AUTH_PASSWORD=change_me_postgres
PGBOUNCER_POOL_MODE=transaction
PGBOUNCER_MAX_CLIENT_CONN=200
PGBOUNCER_DEFAULT_POOL_SIZE=20

# Directus
# SECRET: mind. 32 Zeichen, zufällig generiert (z.B. openssl rand -hex 32)
SECRET=change_me_secret_min_32_chars_long
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_admin

DB_CLIENT=pg
DB_HOST=pgbouncer
DB_PORT=5432
DB_DATABASE=datahub
DB_USER=datahub_user
DB_PASSWORD=change_me_postgres

# Redis Cache — TTL in Sekunden
# CACHE_REDIS: redis://<host>:<port> oder redis://:<password>@<host>:<port> mit Auth
CACHE_ENABLED=true
CACHE_STORE=redis
CACHE_REDIS=redis://redis:6379
CACHE_TTL=30

# CORS — kommagetrennte Domains, kein Trailing-Slash
# Beispiel: https://rnd.de,https://intern.rnd.de
CORS_ENABLED=true
CORS_ORIGIN=https://rnd.de,https://*.rnd.de

# Logging — debug, info, warn, error
LOG_LEVEL=info

# E-Mail (optional, für Passwort-Reset)
# EMAIL_TRANSPORT: sendmail, smtp, mailgun, sendgrid
EMAIL_FROM=noreply@example.com
EMAIL_TRANSPORT=sendmail

# PUBLIC_URL: Vollständige URL unter der Directus erreichbar ist
# In Production: https://datahub.example.com
PUBLIC_URL=http://localhost:8080

# Directus Replicas — Anzahl paralleler Directus-Instanzen hinter Nginx
# Bei mehreren Replicas: Redis wird als geteilter Cache zwingend genutzt
# PgBouncer MAX_CLIENT_CONN sollte DIRECTUS_REPLICAS * DEFAULT_POOL_SIZE abdecken
# Beispiel: 3 Replicas * 20 Pool-Size = 60 → MAX_CLIENT_CONN mind. 100
DIRECTUS_REPLICAS=1
